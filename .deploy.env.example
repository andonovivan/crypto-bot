# Example .deploy.env for deploy.sh
#
# Copy to .deploy.env and fill in:
#   cp .deploy.env.example .deploy.env
#   nano .deploy.env
#
# .deploy.env is gitignored — safe to put your SSH key path here.

# SSH target — the static IP from Lightsail/Vultr
DEPLOY_HOST=ubuntu@1.2.3.4

# Path to the SSH private key downloaded from the cloud console
DEPLOY_KEY=~/.ssh/crypto-bot-tokyo.pem

# Optional — remote install path. Defaults to /home/ubuntu/crypto-bot.
# DEPLOY_PATH=/home/ubuntu/crypto-bot
