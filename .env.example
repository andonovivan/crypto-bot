# Crypto Trading Bot — environment configuration
#
# Copy to .env and fill in. Defaults below are tuned for production servers;
# inline comments call out anything you'd change for local development.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Crypto Bot"
APP_ENV=production                       # use "local" for development
APP_KEY=                                 # generate: docker compose run --rm app php artisan key:generate --show
APP_DEBUG=false                          # NEVER true in production
APP_URL=http://127.0.0.1:8090            # internal — reach via Tailscale or SSH tunnel

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info                           # use "debug" locally; "info" or "warning" on the server

# ── Database (MariaDB inside Docker) ─────────────────────────────────────────
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=crypto_bot
DB_USERNAME=crypto
DB_PASSWORD=                             # set a strong random 32+ char password (e.g. openssl rand -hex 24)

# InnoDB buffer pool in bytes. Default 2 GiB (2147483648) is right for laptops
# running backtests. For a 2 GB production server that doesn't run backtests,
# set MARIADB_BUFFER_POOL_SIZE=268435456 (256 MiB).
MARIADB_BUFFER_POOL_SIZE=268435456

# ── Laravel framework ────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Binance API ──────────────────────────────────────────────────────────────
# Leave BLANK while DRY_RUN=true. When going live:
#   1. Create a Futures-Trading-only key on Binance (NEVER enable withdrawals)
#   2. Whitelist the server's static IP under Binance API access restriction
#   3. Paste here, then `docker compose restart bot ws-worker ws-user-data`
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# ── Trading mode ─────────────────────────────────────────────────────────────
# Master kill switch. Keep TRUE until you're ready to trade real money.
# All other strategy / position settings live in the database (bot_settings)
# and are tuned via the dashboard, not here.
DRY_RUN=true

VITE_APP_NAME="${APP_NAME}"
